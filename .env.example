# Montreal 2027 WorldCon - Docker Environment Configuration
#
# This file is OPTIONAL. The docker-compose.yml already includes these defaults.
# Only create a .env file if you need to override the default values.
#
# To use: Copy this file to .env and customize the values you want to change.

# Web server ports (host -> container)
# Default: localhost:8080 -> container:80
WEB_EXTERNAL_PORT=8080
WEB_INTERNAL_PORT=80

# Database connectivity (internal only - use 'db' as hostname in Docker)
# Defaults: drupal/drupal/drupal
DB_HOST=db
DB_PORT=3306
DB_NAME=drupal
DB_USER=drupal
DB_PASSWORD=drupal
DB_ROOT_PASSWORD=root

# Container names (defaults shown)
WEB_CONTAINER_NAME=montreal2027-web
DB_CONTAINER_NAME=montreal2027-db

# Persistent volume and network names (defaults shown)
DB_VOLUME_NAME=montreal2027_db_data
FRONTEND_NETWORK_NAME=montreal2027_frontend
BACKEND_NETWORK_NAME=montreal2027_backend

# PHP version (default: 8.3, recommended for Drupal 11)
PHP_VERSION=8.3

# MariaDB version (default: 11.4)
MARIADB_VERSION=11.4

# Hash Salt (default for development: RandomHashSaltForDevelopmentPurposesOnly)
# IMPORTANT: Generate a unique random string for production!
# Use: docker-compose exec web drush eval "echo \Drupal\Component\Utility\Crypt::randomBytesBase64(55)"
HASH_SALT=ChangeThisToARandomStringForProduction

# Set this to 'native' or 'docker' based on the current laptop's stack.  This is used by the AI agent configuration
APP_ENV_TYPE=native

# Set to macos or linux native mode.  Ignored in docker mode.
OS_TYPE=macos
